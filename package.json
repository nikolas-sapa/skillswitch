{
  "name": "skillctl",
  "version": "0.1.0",
  "description": "Manage Claude Code skills — profiles, disable/enable, catalog generation",
  "type": "module",
  "bin": { "skillctl": "./dist/cli.js" },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "engines": { "node": ">=18" },
  "license": "MIT",
  "keywords": ["claude", "claude-code", "skills", "ai", "cli"],
  "publishConfig": { "access": "public" }
}
